{
  "manifest_version": 3,
  "name": "Upwork Job Alert",
  "version": "1.0",
  "description": "Alerts you when new DevOps jobs with < 5 connects appear",
  "permissions": ["storage", "notifications", "alarms"],
  "host_permissions": ["https://www.upwork.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.upwork.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png"
  }
}
